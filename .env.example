# JALNETRA AI — Environment Variables
# Copy this file to .env and fill in values. The app runs in Demo Mode without these.

# --- Supabase (pre-populated automatically in Bolt environment) ---
VITE_SUPABASE_URL=your-supabase-project-url
VITE_SUPABASE_ANON_KEY=your-supabase-anon-key

# --- Twilio / WhatsApp Cloud API (optional — falls back to demo preview) ---
# If not set, the WhatsApp advisory shows a preview bubble but does not send a live message.
TWILIO_ACCOUNT_SID=your-twilio-account-sid
TWILIO_AUTH_TOKEN=your-twilio-auth-token
TWILIO_WHATSAPP_NUMBER=whatsapp:+14155238886

# --- What falls back to Demo Mode without each key ---
# Without VITE_SUPABASE_URL / VITE_SUPABASE_ANON_KEY:
#   - Auth (sign in/up) is disabled; site shows a "Demo Mode" badge
#   - Prediction history and profile are not saved
#   - Map uses seeded district data instead of live Supabase rows
# Without TWILIO_*:
#   - WhatsApp/SMS advisory shows an in-app preview bubble but does not send a live message
#   - The edge function returns { simulated: true } so the UI can display "Demo mode"
